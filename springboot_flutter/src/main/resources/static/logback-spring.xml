<!-- 📁 resources/logback-spring.xml -->
<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    
    <!-- ===== VARIABLES DE ENTORNO ===== -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="springboot-flutter"/>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.com.example.springboot_flutter" defaultValue="INFO"/>
    
    <!-- ===== CONSOLA (formato legible para dev) ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <springProfile name="dev">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </springProfile>
        <springProfile name="prod">
            <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
                <layout class="ch.qos.logback.contrib.json.classic.JsonLayout">
                    <timestampFormat>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampFormat>
                    <appendLineSeparator>true</appendLineSeparator>
                    <jsonFormatter class="ch.qos.logback.contrib.jackson.JacksonJsonFormatter"/>
                </layout>
            </encoder>
        </springProfile>
    </appender>
    
    <!-- ===== ARCHIVO LOG (producción) ===== -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/var/log/${APP_NAME}/application.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>/var/log/${APP_NAME}/application.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
                <totalSizeCap>10GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
                <layout class="ch.qos.logback.contrib.json.classic.JsonLayout">
                    <timestampFormat>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampFormat>
                    <appendLineSeparator>true</appendLineSeparator>
                    <jsonFormatter class="ch.qos.logback.contrib.jackson.JacksonJsonFormatter"/>
                </layout>
            </encoder>
        </appender>
        
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
    
    <!-- ===== LOGGERS POR PAQUETE ===== -->
    <logger name="com.example.springboot_flutter" level="${LOG_LEVEL}"/>
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    
    <!-- ===== LOGS DE AUDITORÍA ===== -->
    <logger name="AUDIT" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <springProfile name="prod">
            <appender-ref ref="FILE"/>
        </springProfile>
    </logger>
    
    <!-- ===== ROOT LOGGER ===== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
    
</configuration>